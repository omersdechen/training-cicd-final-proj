{
  "name": "sample-web-app",
  "version": "1.0.0",
  "description": "Sample web application for Jenkins training",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "echo 'Running unit tests...' && node tests/unit/app.test.js",
    "test:integration": "echo 'Running integration tests...' && node tests/integration/api.test.js",
    "test:e2e": "echo 'Running e2e tests...' && node tests/e2e/browser.test.js",
    "lint": "echo 'Running linter...'",
    "build": "echo 'Building application...'",
    "build:prod": "echo 'Building for production...'"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  }
}